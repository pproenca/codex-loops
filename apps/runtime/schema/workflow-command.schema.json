{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "commandPath",
    "workflow",
    "supportedModes"
  ],
  "properties": {
    "commandPath": { "type": "string" },
    "workflow": { "type": "string" },
    "preflight": { "enum": ["markdown-frontmatter-manifest"] },
    "defaultBudget": { "enum": ["small", "standard", "deep"] },
    "defaultMode": { "type": "string" },
    "supportedModes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "readWritePosture": { "type": "string" },
    "relay": { "type": "string" }
  }
}
