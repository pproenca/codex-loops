#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if [ -n "${CODEX_LOOPS_RUNTIME_ROOT:-}" ]; then
  runtime_root=$CODEX_LOOPS_RUNTIME_ROOT
  release_bin=${CODEX_LOOPS_SCHEDULER_BIN:-"$runtime_root/scheduler/bin/agent_loops"}
else
  case "$(basename -- "$script_dir")" in
    mcp)
      runtime_root=$(dirname -- "$script_dir")
      release_bin=${CODEX_LOOPS_SCHEDULER_BIN:-"$runtime_root/scheduler/bin/agent_loops"}
      ;;
    *)
      scheduler_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
      runtime_root=$(dirname -- "$scheduler_root")
      release_bin=${CODEX_LOOPS_SCHEDULER_BIN:-"$script_dir/agent_loops"}
      ;;
  esac
fi

CODEX_LOOPS_RUNTIME_ROOT=$runtime_root
CODEX_LOOPS_SCHEDULER_BIN=$release_bin
RELEASE_DISTRIBUTION=none
export CODEX_LOOPS_RUNTIME_ROOT CODEX_LOOPS_SCHEDULER_BIN RELEASE_DISTRIBUTION

exec "$release_bin" eval 'Workflow.MCP.AnubisStdio.main(System.argv())' "$@"
