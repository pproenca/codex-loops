class CodexLoops < Formula
  desc "Local workflow scheduler and Codex MCP adapter"
  homepage "https://github.com/pproenca/codex-loops"
  url "https://github.com/pproenca/codex-loops/archive/refs/tags/v@VERSION@.tar.gz"
  sha256 "@SHA256@"
  license "MIT"

  depends_on "elixir" => :build
  depends_on "rust" => :build
  depends_on arch: :arm64
  depends_on :macos
  depends_on "openssl@3"

  def install
    ENV["MIX_ENV"] = "prod"
    ENV["HEX_HOME"] = buildpath/".hex"
    ENV["MIX_HOME"] = buildpath/".mix"

    system "mix", "local.hex", "--force"
    system "mix", "local.rebar", "--force"
    system "make", "package-homebrew-runtime",
           "HOMEBREW_PACKAGE_DIR=#{buildpath}/homebrew-package"

    (buildpath/"homebrew-package/libexec").children.each do |artifact|
      libexec.install artifact
    end

    (bin/"codex-loops").write_env_script \
      libexec/"bin/codex-loops", CODEX_LOOPS_RUNTIME_ROOT: libexec
    (bin/"codex-loops-mcp").write_env_script \
      libexec/"mcp/codex-loops-mcp", CODEX_LOOPS_RUNTIME_ROOT: libexec
  end

  def caveats
    <<~EOS
      Install the Codex plugin with:
        codex-loops install
    EOS
  end

  test do
    assert_equal "codex-loops #{version}", shell_output("#{bin}/codex-loops --version").strip
    assert_equal "codex-loops-mcp #{version}", shell_output("#{bin}/codex-loops-mcp --version").strip

    port = free_port
    scheduler = libexec/"scheduler/bin/agent_loops"
    log = testpath/"scheduler.log"
    env = {
      "CODEX_LOOPS_SERVER"       => "1",
      "CODEX_LOOPS_HOST"         => "127.0.0.1",
      "CODEX_LOOPS_PORT"         => port.to_s,
      "CODEX_LOOPS_JOURNAL_PATH" => (testpath/"runs.sqlite").to_s,
      "RELEASE_DISTRIBUTION"     => "none",
      "RELEASE_NODE"             => "codex_loops_brew_test",
      "RELEASE_TMP"              => (testpath/"release-tmp").to_s,
    }

    pid = spawn env, scheduler, "start", [:out, :err] => log.to_s

    begin
      health = nil
      100.times do
        sleep 0.1
        health = Utils.safe_popen_read("curl", "--silent", "--fail", "http://127.0.0.1:#{port}/api/health")
        break if health.include?('"status":"ok"')
      rescue ErrorDuringExecution
        next
      end

      assert_match %Q("version":"#{version}"), health

      workflow = testpath/"formula-proof.exs"
      workflow.write <<~ELIXIR
        defmodule FormulaProof do
          use Workflow
          workflow "formula-proof" do
            return :ok
          end
        end
      ELIXIR

      validation = pipe_output(
        "curl --silent --fail --request POST --header 'content-type: application/json' " \
        "--data @- http://127.0.0.1:#{port}/api/workflows/validate",
        JSON.generate({ script_path: workflow.to_s }),
      )
      assert_match '"status":"valid"', validation

      rpc = [
        { jsonrpc: "2.0", id: 1, method: "initialize", params: {
          protocolVersion: "2024-11-05", capabilities: {}, clientInfo: { name: "brew-test", version: "1" }
        } },
        { jsonrpc: "2.0", method: "notifications/initialized", params: {} },
        { jsonrpc: "2.0", id: 2, method: "tools/list", params: {} },
      ].map { |message| JSON.generate(message) }.join("\n") << "\n"

      mcp = pipe_output("#{bin}/codex-loops-mcp --stdio", rpc)
      assert_match '"name":"workflow_validate"', mcp
      assert_match %Q("version":"#{version}"), mcp
    ensure
      system env, scheduler, "stop"
      Process.wait(pid)
    end
  end
end
