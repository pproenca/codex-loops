{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "workflowName",
    "status",
    "scriptPath",
    "databasePath",
    "args",
    "phases",
    "logs",
    "agentCount",
    "totalTokens",
    "totalToolCalls"
  ],
  "properties": {
    "schemaVersion": { "const": "workflow-snapshot/v2" },
    "runId": { "type": "string" },
    "workflowName": { "type": "string" },
    "status": { "enum": ["queued", "running", "done", "failed", "killed"] },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pid"],
      "properties": {
        "pid": { "type": "number" },
        "startedAt": { "type": "string" },
        "lastHeartbeatTs": { "type": "string" }
      }
    },
    "scriptPath": { "type": "string" },
    "scriptSha256": { "type": "string" },
    "databasePath": { "type": "string" },
    "args": {},
    "phases": { "type": "array", "items": { "$ref": "#/$defs/phase" } },
    "logs": { "type": "array", "items": { "type": "string" } },
    "result": {},
    "error": { "type": "string" },
    "agentCount": { "type": "number" },
    "totalTokens": { "type": "number" },
    "totalToolCalls": { "type": "number" },
    "durationMs": { "type": "number" },
    "budgetPlan": { "$ref": "#/$defs/budgetPlan" },
    "limits": { "$ref": "#/$defs/limits" },
    "runtimeContract": { "$ref": "#/$defs/runtimeContract" },
    "lastSeq": { "type": "integer", "minimum": 0 },
    "truncatedTail": { "type": "boolean" }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "title", "status", "nodes"],
      "properties": {
        "index": { "type": "number" },
        "title": { "type": "string" },
        "status": { "enum": ["pending", "running", "completed", "failed", "killed"] },
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "state",
        "attempt",
        "promptHash",
        "optionsHash",
        "promptPreview",
        "tokens",
        "toolCalls",
        "durationMs"
      ],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "phase": { "type": "number" },
        "phaseTitle": { "type": "string" },
        "state": { "enum": ["queued", "running", "done", "failed", "killed"] },
        "attempt": { "type": "number" },
        "promptHash": { "type": "string" },
        "schemaHash": { "type": "string" },
        "optionsHash": { "type": "string" },
        "promptPreview": { "type": "string" },
        "promptFull": { "type": "string" },
        "model": { "type": "string" },
        "effort": { "enum": ["medium", "high", "xhigh"] },
        "routeReason": { "type": "string" },
        "agentType": { "type": "string" },
        "agentDefinitionSha": { "type": "string" },
        "isolation": { "type": "string" },
        "risk": { "type": "string" },
        "threadId": { "type": "string" },
        "lastToolName": { "type": "string" },
        "lastToolSummary": { "type": "string" },
        "result": {},
        "error": { "type": "string" },
        "tokens": { "type": "number" },
        "toolCalls": { "type": "number" },
        "durationMs": { "type": "number" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxAgents",
        "maxConcurrentAgents",
        "schemaRetryLimit",
        "maxWorkItemsPerAgent",
        "maxInventoryItemsReturned",
        "maxPromptBytesPerAgent",
        "maxMutationFilesPerAgent",
        "maxMutationFilesPerRun",
        "maxParallelItems",
        "maxPipelineItems"
      ],
      "properties": {
        "maxAgents": { "type": "number" },
        "maxConcurrentAgents": { "type": "number" },
        "schemaRetryLimit": { "type": "number" },
        "maxWorkItemsPerAgent": { "type": "number" },
        "maxInventoryItemsReturned": { "type": "number" },
        "maxPromptBytesPerAgent": { "type": "number" },
        "maxMutationFilesPerAgent": { "type": "number" },
        "maxMutationFilesPerRun": { "type": "number" },
        "maxParallelItems": { "type": "number" },
        "maxPipelineItems": { "type": "number" },
        "maxToolCallsPerAgent": { "type": "number" },
        "maxToolCallsPerRun": { "type": "number" },
        "taskBudgetTokens": { "type": "number" },
        "minRemainingTokensForAgent": { "type": "number" }
      }
    },
    "workloadPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scopeKind", "batchable", "runCompleteness", "basis"],
      "properties": {
        "scopeKind": { "enum": ["bounded", "repo-wide", "unknown"] },
        "expectedInputItems": { "type": "number" },
        "maxCandidateItems": { "type": "number" },
        "maxMutationFilesPerRun": { "type": "number" },
        "maxMutationFilesPerAgent": { "type": "number" },
        "maxPromptBytesPerAgent": { "type": "number" },
        "batchable": { "type": "boolean" },
        "runCompleteness": { "enum": ["full", "partial", "plan-only"] },
        "basis": { "type": "string" }
      }
    },
    "budgetPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "limits",
        "expectedAgents",
        "workload",
        "modelPolicySummary",
        "writeScope",
        "tokenWarning"
      ],
      "properties": {
        "provider": { "enum": ["sdk", "mock"] },
        "limits": { "$ref": "#/$defs/limits" },
        "expectedAgents": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum", "maximum", "basis"],
          "properties": {
            "minimum": { "type": "number" },
            "maximum": { "type": "number" },
            "basis": { "type": "string" }
          }
        },
        "workload": { "$ref": "#/$defs/workloadPlan" },
        "modelPolicySummary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["defaultEffort", "minEffort", "maxEffort", "disallowedEfforts"],
          "properties": {
            "defaultModel": { "type": "string" },
            "defaultEffort": { "type": "string" },
            "minEffort": { "type": "string" },
            "maxEffort": { "type": "string" },
            "disallowedEfforts": { "type": "array", "items": { "type": "string" } }
          }
        },
        "writeScope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["posture", "summary"],
          "properties": {
            "posture": { "enum": ["read-only", "workspace-write", "mixed", "full-access"] },
            "summary": { "type": "string" }
          }
        },
        "tokenWarning": { "type": "string" },
        "dollarEstimate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "reason"],
          "properties": {
            "enabled": { "type": "boolean" },
            "reason": { "type": "string" }
          }
        }
      }
    },
    "runtimeContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activation",
        "permission",
        "structuredOutput",
        "scheduling",
        "budgeting",
        "resume",
        "remote"
      ],
      "properties": {
        "activation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed", "source", "command", "reason"],
          "properties": {
            "allowed": { "type": "boolean" },
            "source": { "enum": ["cli-command", "programmatic-api", "runner-api"] },
            "command": { "type": "string" },
            "reason": { "type": "string" }
          }
        },
        "permission": {
          "type": "object",
          "additionalProperties": false,
          "required": ["decision", "source", "autoDenied", "ruleText"],
          "properties": {
            "decision": { "enum": ["allow", "caller-owned", "deny"] },
            "source": { "type": "string" },
            "autoDenied": { "type": "boolean" },
            "ruleText": { "type": "string" },
            "targetSettingsSource": { "type": "string" }
          }
        },
        "structuredOutput": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "failClosed", "schemaRetryLimit"],
          "properties": {
            "mode": { "const": "provider-schema" },
            "failClosed": { "const": true },
            "schemaRetryLimit": { "type": "number" }
          }
        },
        "scheduling": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "maxAgents",
            "maxConcurrentAgents",
            "queueExcessAgents",
            "queueStateVisible",
            "releaseSlotsOnTerminalState"
          ],
          "properties": {
            "maxAgents": { "type": "number" },
            "maxConcurrentAgents": { "type": "number" },
            "queueExcessAgents": { "const": true },
            "queueStateVisible": { "const": true },
            "releaseSlotsOnTerminalState": { "const": true }
          }
        },
        "budgeting": {
          "type": "object",
          "additionalProperties": false,
          "required": ["accountingFields", "thresholdPolicy"],
          "properties": {
            "taskBudgetTokens": { "type": "number" },
            "minRemainingTokensForAgent": { "type": "number" },
            "accountingFields": { "type": "array", "items": { "type": "string" } },
            "thresholdPolicy": { "type": "string" }
          }
        },
        "resume": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cacheKey", "completedNodesReplayFromJournal"],
          "properties": {
            "cacheKey": { "const": "runId+phaseTitle+label+promptHash+schemaHash+optionsHash" },
            "completedNodesReplayFromJournal": { "const": true }
          }
        },
        "remote": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supported", "reason"],
          "properties": {
            "supported": { "const": false },
            "reason": { "type": "string" }
          }
        }
      }
    }
  }
}
