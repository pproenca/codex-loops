#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if [ -n "${CODEX_LOOPS_RUNTIME_ROOT:-}" ]; then
  release_bin=${CODEX_LOOPS_SCHEDULER_BIN:-"$CODEX_LOOPS_RUNTIME_ROOT/scheduler/bin/agent_loops"}
else
  scheduler_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
  CODEX_LOOPS_RUNTIME_ROOT=$(dirname -- "$scheduler_root")
  release_bin=${CODEX_LOOPS_SCHEDULER_BIN:-"$script_dir/agent_loops"}
  export CODEX_LOOPS_RUNTIME_ROOT
fi

CODEX_LOOPS_SCHEDULER_BIN=$release_bin
RELEASE_DISTRIBUTION=none
export CODEX_LOOPS_SCHEDULER_BIN RELEASE_DISTRIBUTION

exec "$release_bin" eval 'Workflow.CLI.main(System.argv())' "$@"
