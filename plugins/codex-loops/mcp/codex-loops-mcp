#!/bin/sh
set -eu

plugin_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
plugin_version=$(
  sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
    "$plugin_root/.codex-plugin/plugin.json" | head -n 1
)

fail_missing() {
  cat >&2 <<EOF
Codex Loops runtime was not found.

Install it with:
  brew install pproenca/codex-loops/codex-loops
  codex-loops install
EOF
  exit 1
}

fail_root() {
  cat >&2 <<EOF
CODEX_LOOPS_RUNTIME_ROOT is set but does not contain a usable Codex Loops runtime:
  $1

Expected:
  $1/mcp/codex-loops-mcp
  $1/scheduler/bin/agent_loops

Install it with:
  brew install pproenca/codex-loops/codex-loops
EOF
  exit 1
}

runtime_root_for() {
  candidate=$1
  candidate_dir=$(CDPATH= cd -- "$(dirname -- "$candidate")" 2>/dev/null && pwd) || return 1

  case "$(basename -- "$candidate_dir")" in
    mcp) dirname -- "$candidate_dir" ;;
    bin)
      parent=$(dirname -- "$candidate_dir")
      if [ "$(basename -- "$parent")" = "scheduler" ]; then
        dirname -- "$parent"
      elif [ -d "$parent/opt/codex-loops/libexec" ]; then
        printf '%s\n' "$parent/opt/codex-loops/libexec"
      else
        dirname -- "$candidate_dir"
      fi
      ;;
    *) dirname -- "$candidate_dir" ;;
  esac
}

compatible_runtime() {
  candidate=$1
  root=$2
  shift 2
  scheduler=${CODEX_LOOPS_SCHEDULER_BIN:-"$root/scheduler/bin/agent_loops"}

  [ -x "$candidate" ] || return 1
  [ -x "$scheduler" ] || return 1
  [ "$candidate" -ef "$0" ] 2>/dev/null && return 1

  version_output=$("$candidate" --version 2>/dev/null) || return 1
  runtime_version=${version_output#codex-loops-mcp }
  [ "$runtime_version" != "$version_output" ] || return 1

  if [ "$runtime_version" != "$plugin_version" ]; then
    cat >&2 <<EOF
Codex Loops plugin/runtime version mismatch.
Plugin:  $plugin_version
Runtime: $runtime_version

Repair with:
  brew upgrade pproenca/codex-loops/codex-loops
  codex-loops install
EOF
    exit 1
  fi

  CODEX_LOOPS_PLUGIN_ROOT=$plugin_root
  CODEX_LOOPS_RUNTIME_ROOT=$root
  CODEX_LOOPS_SCHEDULER_BIN=$scheduler
  export CODEX_LOOPS_PLUGIN_ROOT CODEX_LOOPS_RUNTIME_ROOT CODEX_LOOPS_SCHEDULER_BIN
  exec "$candidate" "$@"
}

if [ -n "${CODEX_LOOPS_MCP_BIN:-}" ]; then
  case "$CODEX_LOOPS_MCP_BIN" in
    /*) ;;
    *) echo "CODEX_LOOPS_MCP_BIN must be an absolute path: $CODEX_LOOPS_MCP_BIN" >&2; exit 1 ;;
  esac

  root=${CODEX_LOOPS_RUNTIME_ROOT:-$(runtime_root_for "$CODEX_LOOPS_MCP_BIN")}
  compatible_runtime "$CODEX_LOOPS_MCP_BIN" "$root" "$@"
  fail_missing
fi

if [ -n "${CODEX_LOOPS_RUNTIME_ROOT:-}" ]; then
  root=$CODEX_LOOPS_RUNTIME_ROOT
  candidate="$root/mcp/codex-loops-mcp"
  [ -x "$candidate" ] && [ -x "$root/scheduler/bin/agent_loops" ] || fail_root "$root"
  compatible_runtime "$candidate" "$root" "$@"
  fail_root "$root"
fi

if candidate=$(command -v codex-loops-mcp 2>/dev/null); then
  root=$(runtime_root_for "$candidate")
  compatible_runtime "$candidate" "$root" "$@"
fi

if command -v brew >/dev/null 2>&1; then
  prefix=$(brew --prefix codex-loops 2>/dev/null || true)
  if [ -n "$prefix" ]; then
    root="$prefix/libexec"
    compatible_runtime "$root/mcp/codex-loops-mcp" "$root" "$@"
  fi
fi

for root in \
  /opt/homebrew/opt/codex-loops/libexec \
  /usr/local/opt/codex-loops/libexec
do
  compatible_runtime "$root/mcp/codex-loops-mcp" "$root" "$@"
done

fail_missing
